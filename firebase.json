{
  "hosting": {
    "public": "frontend/hugo-landing/public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/acc/stakeholder-kickoff/zoom-meeting",
        "destination": "/acc/stakeholder-kickoff/zoom-meeting/",
        "type": 301
      },
      {
        "source": "/acc/stakeholder-kickoff/outreach-email",
        "destination": "/acc/stakeholder-kickoff/outreach-email/",
        "type": 301
      },
      {
        "source": "/acc/stakeholder-kickoff/brief-organize",
        "destination": "/acc/stakeholder-kickoff/brief-organize/",
        "type": 301
      },
      {
        "source": "/acc/stakeholder-kickoff/workspace",
        "destination": "/acc/stakeholder-kickoff/workspace/",
        "type": 301
      },
      {
        "source": "/acc/stakeholder-kickoff/gap-analysis",
        "destination": "/acc/stakeholder-kickoff/gap-analysis/",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "heerise-backend",
          "region": "us-central1"
        }
      }
    ],
    "headers": [
      {
        "source": "**/*.@(css|js|png|jpg|jpeg|gif|svg|ico|woff|woff2)",
        "headers": [{ "key": "Cache-Control", "value": "max-age=31536000,immutable" }]
      },
      {
        "source": "**/favicon.ico",
        "headers": [{ "key": "Cache-Control", "value": "max-age=3600, must-revalidate" }]
      },
      {
        "source": "**/apple-touch-icon.png",
        "headers": [{ "key": "Cache-Control", "value": "max-age=3600, must-revalidate" }]
      }
    ]
  }
}
